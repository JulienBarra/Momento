# Remplace ces 2 domaines par les tiens avant de déployer.
# Caddy gère automatiquement le HTTPS (Let's Encrypt) — il te faut juste
# que les DNS A/AAAA de ces domaines pointent déjà vers l'IP du VPS.

{$FRONTEND_DOMAIN} {
    reverse_proxy frontend:80
}

{$API_DOMAIN} {
    @uploads path /uploads/*
    header @uploads Cache-Control "public, max-age=31536000, immutable"
    reverse_proxy backend:3333
}
