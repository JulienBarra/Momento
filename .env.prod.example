# =======================================================
# Fichier à copier en `.env` sur le VPS (au même niveau
# que docker-compose.prod.yml) et à remplir avant
# le `docker compose -f docker-compose.prod.yml up -d`.
# =======================================================

# --- Domaines (DNS A/AAAA pointant vers le VPS) ---
FRONTEND_DOMAIN=momento.example.com
API_DOMAIN=api.momento.example.com

# --- Postgres ---
POSTGRES_USER=momento_admin
POSTGRES_PASSWORD=                  # à générer (ex: openssl rand -base64 24)
POSTGRES_DB=momento_db

# --- Backend AdonisJS ---
APP_KEY=                            # à générer (ex: openssl rand -hex 16)
ADMIN_TOKEN=                        # à générer (ex: openssl rand -hex 32)
